{{- /* Claude Code settings — paths are machine-specific */ -}}
{
  "env": {
{{- if eq .os "darwin" }}
    "ANTHROPIC_BASE_URL": "{{ output "security" "find-generic-password" "-a" "yamer003" "-s" "work-genai-base-url" "-w" | trim }}",
    "ANTHROPIC_AUTH_TOKEN": "{{ output "security" "find-generic-password" "-a" "yamer003" "-s" "litellm-api-key" "-w" | trim }}",
    "NODE_EXTRA_CA_CERTS": "{{ .chezmoi.homeDir }}/.claude/certs/corporate-ca-bundle.pem",
{{- else }}
    "ANTHROPIC_BASE_URL": "{{ output "secret-tool" "lookup" "service" "work-genai-base-url" "account" "yamer003" | trim }}",
    "ANTHROPIC_AUTH_TOKEN": "{{ output "secret-tool" "lookup" "service" "litellm-api-key" "account" "yamer003" | trim }}",
{{- end }}
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "bedrock.anthropic.claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "bedrock.anthropic.claude-opus-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "bedrock.anthropic.claude-haiku-4-5",
    "DISABLE_PROMPT_CACHING": "1"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
