{{- /* BB9 env — API key from native OS keychain */ -}}
{{- if eq .os "darwin" -}}
OPENAI_API_KEY={{ output "security" "find-generic-password" "-a" "yamer003" "-s" "bb9-api-key" "-w" | trim }}
{{- else -}}
OPENAI_API_KEY={{ output "secret-tool" "lookup" "service" "bb9-api-key" "account" "yamer003" | trim }}
{{- end }}
