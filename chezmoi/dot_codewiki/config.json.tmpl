{{- /* codewiki config — base_url from Keychain */ -}}
{
  "version": "1.0",
{{- if eq .os "darwin" }}
  "base_url": "{{ output "security" "find-generic-password" "-a" "yamer003" "-s" "work-genai-base-url" "-w" | trim }}",
{{- else }}
  "base_url": "{{ output "secret-tool" "lookup" "service" "work-genai-base-url" "account" "yamer003" | trim }}",
{{- end }}
  "main_model": "bedrock.anthropic.claude-opus-4-7",
  "cluster_model": "bedrock.anthropic.claude-opus-4-7",
  "default_output": "docs",
  "provider": "openai-compatible",
  "aws_region": "us-east-1",
  "api_version": "2024-12-01-preview",
  "azure_deployment": "",
  "max_tokens": 32768,
  "max_token_per_module": 200000,
  "max_token_per_leaf_module": 100000,
  "max_depth": 3
}
