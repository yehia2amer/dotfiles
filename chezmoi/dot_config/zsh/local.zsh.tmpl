fi
{{- end }}

{{- if .work }}
# ── Corporate CA certificates ──
CA={{ keyring "work-ca-cert-path" "yamer003" }}
if [ -f "$CA" ]; then
  export SSL_CERT_FILE="$CA"
  export REQUESTS_CA_BUNDLE="$CA"
  export CURL_CA_BUNDLE="$CA"
