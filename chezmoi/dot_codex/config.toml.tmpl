{{- /* Codex config — base_url from Keychain at chezmoi apply time */ -}}
{{- if eq .os "darwin" -}}
{{- $baseUrl := output "security" "find-generic-password" "-a" "yamer003" "-s" "work-genai-base-url" "-w" | trim -}}
model = "openai.gpt-5.5"
model_provider = "openai_compatible"
personality = "pragmatic"
model_reasoning_effort = "medium"

[model_providers.openai_compatible]
name = "LiteLLM OpenAI-compatible"
base_url = "{{ $baseUrl }}/v1"
env_key = "OPENAI_API_KEY"
model_context_window = 1050000
{{- else -}}
{{- $baseUrl := output "secret-tool" "lookup" "service" "work-genai-base-url" "account" "yamer003" | trim -}}
model = "openai.gpt-5.5"
model_provider = "openai_compatible"
personality = "pragmatic"
model_reasoning_effort = "medium"

[model_providers.openai_compatible]
name = "LiteLLM OpenAI-compatible"
base_url = "{{ $baseUrl }}/v1"
env_key = "OPENAI_API_KEY"
model_context_window = 1050000
{{- end }}

[mcp_servers.gitnexus]
command = "{{ .chezmoi.homeDir }}/.bun/bin/gitnexus"
args = ["mcp"]
